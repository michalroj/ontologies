{
  "@context": {
    "@vocab": "https://michalroj.github.io/ontologies/ontologies/ExamsAndQuestions.ttl#",
    "eop":    "https://michalroj.github.io/ontologies/ontologies/ExamsAndQuestions.ttl#",
    "schema": "https://schema.org/",
    "xsd":    "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type", 
    "objects": "@graph",

    "exam_id": "eop:exam_id",
    "variant": "eop:exam_variant",
    "publicationDate": "schema:datePublished",
    "source": "eop:publicallyAccessibleLink",

    "number": "eop:questionNumber",
    "page": "eop:pageOnTheSheet",
    "exam_sheet_id": { "@id": "eop:exam_sheet_id", "@type": "@id" },
    "sub_questions": "eop:subQuestions",
    "related_questions": "eop:relatedQuestions",

    "attempt_date": "eop:attemptDate",
    "points_per_question": "eop:pointsPerQuestion",
    "score": "eop:score",

    "analysis_complete": null,
    "title": "schema:name",
    "statement": "eop:questionSummary",
    "given_data": "eop:givenData",
    "comment": "eop:questionAbstract", 
    "paraphrase": "eop:questionParaphase",
    "open_version": "eop:openQuestionParaphase",
    "tricky": "eop:trickyAreas",
    "problems": "eop:problems",

    "formulas": { "@id": "eop:usesFormula", "@type": "@id" },
    "formulas_from_wzory_comment": { "@id": "math_pl:formula", "@type": "@id" },
    "question": "eop:questionOrTask", 
    "graphics": "eop:graphicsDescription",
    "math_branch": null,
    "math_branch_area": null,

    "solution_approach": "eop:solutionApproach",
    "needed_knowledge": "eop:neededKnowledge", 
    "solution": "eop:solutionDescription", 
    "result_value": "eop:resultValue",
    "result_sheet": "eop:resultSheetOption",

    "math_branch_nodes": { "@id": "eop:mathBranch", "@type": "@id" },
    "math_branch_area_nodes": { "@id": "eop:mathArea", "@type": "@id" }

  }
}
